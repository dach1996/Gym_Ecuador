{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean bin and obj",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/scripts/clean-bin-obj.ps1"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "build AdministratorApi",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/AdministratorApi/AdministratorApi.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build GatewayCoreAPI",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/GatewayCoreAPI/GatewayCoreAPI.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish GatewayCoreAPI",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/GatewayCoreAPI/GatewayCoreAPI.csproj",
                "--configuration",
                "${input:build_env}",
                "--output",
                "${config:publish_path}/${input:build_env}/GatewayCoreAPI"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish AdministratorApi",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/AdministratorApi/AdministratorApi.csproj",
                "--configuration",
                "${input:build_env}",
                "--output",
                "${config:publish_path}/${input:build_env}/AdministratorApi"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Publish All",
            "dependsOrder": "sequence",
            "dependsOn": [
                "clean",
                "publish AdministratorApi",
                "publish GatewayCoreAPI",
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ],
    "inputs": [
        {
            "id": "build_env",
            "description": "Build Environment",
            "type": "pickString",
            "options": [
                "Develop",
                "Staging"
            ]
        }
    ]
}